# Server port — Railway/Render/Fly.io set this automatically
PORT=8787

# Directory where customs.db is stored.
# Point this at a persistent volume mount in production (e.g. /data).
# Omit locally — defaults to %APPDATA%\customs-calculator\ on Windows
# or ~/.customs-calculator/ on Linux/macOS.
DATA_DIR=/data

# Optional but recommended in production.
# Protects admin/runtime/import/review endpoints.
ADMIN_API_KEY=replace-with-a-long-random-secret

# Optional frontend helper: if set at build time, the browser sends this key
# on protected admin endpoints. Prefer localStorage for local/dev usage.
VITE_ADMIN_API_KEY=

NODE_ENV=production
