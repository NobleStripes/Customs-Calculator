{
  "name": "customs-calculator",
  "version": "0.1.0",
  "description": "Philippines Customs Duty & Compliance Calculator - Desktop Application",
  "main": "dist/main/index.js",
  "homepage": "./",
  "author": "Your Name",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist/main/index.js --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist/main/index.js --minify",
    "build:renderer": "vite build",
    "start": "cross-env NODE_ENV=production electron dist/main/index.js",
    "electron": "electron dist/main/index.js",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\""
  },
  "dependencies": {
    "sqlite3": "^5.1.6",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "axios": "^1.7.0",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/sqlite3": "^3.1.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.20.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "pdfkit": "^0.13.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.1.0"
  }
}
