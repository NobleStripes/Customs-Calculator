{
  // https://www.electron.build/configuration/configuration
  appId: "com.ph.customscalculator",
  productName: "Philippines Customs Calculator",
  directories: {
    output: "release",
    buildResources: "assets",
  },
  files: [
    "dist",
    "node_modules",
  ],
  win: {
    target: [
      {
        target: "nsis",
        arch: ["x64"],
      },
      {
        target: "portable",
        arch: ["x64"],
      },
    ],
    artifactName: "${productName}-${version}.${ext}",
  },
  nsis: {
    oneClick: false,
    allowToChangeInstallationDirectory: true,
    createDesktopShortcut: true,
    createStartMenuShortcut: true,
    shortcutName: "Philippines Customs Calculator",
  },
  mac: {
    target: ["dmg", "zip"],
    artifactName: "${productName}-${version}.${ext}",
    category: "public.app-category.business",
  },
  linux: {
    target: ["AppImage", "deb"],
    artifactName: "${productName}-${version}.${ext}",
  },
}
